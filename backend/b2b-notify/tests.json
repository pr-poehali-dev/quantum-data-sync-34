      "expectedStatus": 200,
      "expectedBody": { "success": true },
      "bodyMatcher": "partial"
    },
    {
      "name": "Ошибка — нет имени",
      "method": "POST",
      "path": "/",
      "body": { "phone": "+79001234567" },
      "expectedStatus": 400,
      "expectedBody": { "error": "Name and phone required" },
      "bodyMatcher": "partial"
    }
